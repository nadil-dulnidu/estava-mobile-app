{
  "expo": {
    "name": "Estava",
    "slug": "estava-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "updates": {
      "enabled": false
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.estava.mobile",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.estava.mobile",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Estava needs access to your photo library so you can upload property images."
      }
    },
    "extra": {
      "eas": {
        "projectId": "130e5999-a59f-47d1-8460-d1751685ba67"
      }
    }
  }
}
